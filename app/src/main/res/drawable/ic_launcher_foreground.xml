<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive Icon Foreground.
  Using negative margins to "zoom in" on the logo and push the black edges
  of the PNG outside the visible mask area.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@drawable/app_logo"
        android:gravity="center"
        android:top="-18dp"
        android:bottom="-18dp"
        android:left="-18dp"
        android:right="-18dp" />
</layer-list>
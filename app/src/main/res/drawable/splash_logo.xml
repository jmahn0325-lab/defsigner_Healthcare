<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash Screen Logo.
  The system masks this icon in a circle.
  By setting small or negative margins, we ensure the white part of the
  logo fills the circle, effectively hiding the black corners of the PNG.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>
    <item
        android:drawable="@drawable/app_logo"
        android:gravity="center"
        android:top="0dp"
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp" />
</layer-list>